{
  "rules": {
    "presence": {
      "$instanceId": {
        ".read": "auth != null && auth.token.game_instance_id == $instanceId",
        "$participantId": {
          ".write": "auth != null && auth.uid == $participantId && auth.token.game_instance_id == $instanceId"
        }
      }
    },
    "attending": {
      "$instanceId": {
        ".read": "auth != null && auth.token.game_instance_id == $instanceId",
        ".write": false
      }
    },
    "auctions": {
      "$instanceId": {
        "$groupId": {
          ".read": "auth != null && root.child('auctionMembers').child($instanceId).child(auth.uid).val() === $groupId",
          ".write": false
        }
      }
    },
    "auctionMembers": {
      ".read": false,
      ".write": false
    },
    ".read": false,
    ".write": false
  }
}
